PROJECT_NAME           = "threading_library"
PROJECT_NUMBER         = "0.1.0"
OUTPUT_DIRECTORY       = _build/docs
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = YES
OUTPUT_LANGUAGE        = English
MARKDOWN_SUPPORT       = YES
USE_MDFILE_AS_MAINPAGE = README.md

INPUT                  = README.md Docs Library/Includes Examples Tests
FILE_PATTERNS          = *.md *.hpp *.cpp *.cmake CMakeLists.txt
RECURSIVE              = YES
EXCLUDE_PATTERNS       = _build/* Docs/Resources/*

GENERATE_HTML          = YES
GENERATE_LATEX         = NO
HTML_OUTPUT            = html
GENERATE_TREEVIEW      = YES

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES

QUIET                  = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES

HAVE_DOT               = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
DOT_IMAGE_FORMAT       = svg
